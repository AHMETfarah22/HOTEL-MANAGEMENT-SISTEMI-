# =============================================
# ORYS - Çevre Değişkenleri ŞABLON
# =============================================
# Bu dosya .env dosyasının bir şablonudur.
# Projeyi indiren kişi bu dosyayı .env olarak
# kopyalayıp kendi bilgilerini doldurmalıdır.
# =============================================

# Veritabanı Ayarları
DB_SERVER=localhost
DB_PORT=3306
DB_NAME=orys_db
DB_USER=root
DB_PASSWORD=

# E-posta (Gmail SMTP) Ayarları
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
